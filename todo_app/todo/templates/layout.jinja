{% from "macros/nav.jinja" import header %}
{% from "macros/footer.jinja" import footer %}
{% from "macros/messages.jinja" import messages %}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/main.css') }}">
</head>
<body>
    {{ header(current_user.username if current_user.is_authenticated else none) }}
    {{ messages() }}
    {% block content %} {% endblock %}
    {{ footer() }}
</body>
</html>