{% extends "layout.jinja" %}

{% block content %}
<div class="container">
    <div class="title">Please Register</div>
</div>
<form name="register" method="post" class="form">
    <div class="form-group">
        {{ form.hidden_tag() }}
        {{ form.csrf_token }}

        {{ form.username.label(class_="form-label") }}
        {{ form.username(class_="form-field") }}
    </div>
    <div class="form-group">
        {{ form.password.label(class_="form-label") }}
        {{ form.password(class_="form-field") }}

        {{ form.confirm_password.label(class_="form-label") }}
        {{ form.confirm_password(class_="form-field") }}
    </div>
    <div class="form-group-button">
        {{ form.submit(class_="form-button") }}
    </div>
</form>
{% endblock %}